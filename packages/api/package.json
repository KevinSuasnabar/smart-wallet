{
  "name": "@smart-wallet/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./handlers/*": "./src/handlers/*"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist .turbo .serverless *.tsbuildinfo",
    "dev": "echo 'serverless offline not configured yet' && exit 0",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.785.0",
    "@aws-sdk/client-sqs": "^3.1063.0",
    "@aws-sdk/lib-dynamodb": "^3.785.0",
    "@grammyjs/conversations": "^2.0.0",
    "@smart-wallet/domain": "workspace:*",
    "@smart-wallet/shared-types": "workspace:*",
    "aws-jwt-verify": "^4.0.1",
    "grammy": "^1.43.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147"
  }
}
