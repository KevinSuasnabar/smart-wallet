# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# AWS / CDK / Serverless
cdk.out/
.serverless/
.aws-sam/
.cdk.staging/
# cdk-outputs files contain account-specific resource IDs (UserPoolId, TableName, etc.).
# Technically public for our public-client setup, but consistent with our "no values
# in git" policy. Pass values via env vars or read from SSM at deploy time.
**/cdk-outputs*.json

# Environment — ignore ALL .env files except the template.
# Even "public" build-time values (VITE_*) should NOT be committed as a matter of
# policy: one consistent rule across the codebase, no "is this one safe?" debates.
.env
.env.*
!.env.example

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Local DynamoDB
.dynamodb/

# Misc
*.tgz
.cache/
